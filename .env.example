# Environment Configuration Template
# Copy to .env and fill in actual values

# PostgreSQL
POSTGRES_USER=sentinelx_admin
POSTGRES_PASSWORD=SecurePass@123
POSTGRES_DATABASE=auth_db

# Redis
REDIS_PASSWORD=RedisPass@123

# RabbitMQ
RABBITMQ_USER=sentinelx
RABBITMQ_PASSWORD=RabbitPass@123
RABBITMQ_VHOST=/sentinelx

# JWT Configuration
JWT_SECRET_KEY=SentinelX-Super-Secret-Key-Change-In-Production-At-Least-32-Characters
JWT_ISSUER=https://sentinelx.com
JWT_AUDIENCE=SentinelXApi
JWT_EXPIRATION_MINUTES=30

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@sentinelx.com
SMTP_PASSWORD=your-app-password

# Application Settings
ASPNETCORE_ENVIRONMENT=Development
LOG_LEVEL=Information

# API Gateway
GATEWAY_PORT=5000

# Service Ports
AUTH_SERVICE_PORT=5001
USER_SERVICE_PORT=5002
AUDIT_SERVICE_PORT=5003
SECURITY_ENGINE_PORT=5004
NOTIFICATION_SERVICE_PORT=5005

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Feature Flags
ENABLE_TWO_FACTOR=true
ENABLE_AUDIT_LOGGING=true
ENABLE_RATE_LIMITING=true
ENABLE_IP_BLOCKING=true
