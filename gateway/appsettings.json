{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/auth/{**catch-all}"
          }
        ]
      },
      "users-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/users/{**catch-all}"
          }
        ]
      },
      "audit-route": {
        "ClusterId": "audit-cluster",
        "Match": {
          "Path": "/api/audit/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/audit/{**catch-all}"
          }
        ]
      },
      "security-route": {
        "ClusterId": "security-cluster",
        "Match": {
          "Path": "/api/security/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/security/{**catch-all}"
          }
        ]
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/notifications/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://auth-service:5001"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-destination": {
            "Address": "http://user-service:5002"
          }
        }
      },
      "audit-cluster": {
        "Destinations": {
          "audit-destination": {
            "Address": "http://audit-service:5003"
          }
        }
      },
      "security-cluster": {
        "Destinations": {
          "security-destination": {
            "Address": "http://security-engine:5004"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-destination": {
            "Address": "http://notification-service:5005"
          }
        }
      }
    }
  },
  "Jwt": {
    "Authority": "https://localhost:5001",
    "Audience": "SentinelXApi"
  }
}
